{
  "apiVersion": "cmf.confluent.io/v1",
  "kind": "ComputePool",
  "metadata": {
    "name": "cdc-pool"
  },
  "spec": {
    "flinkVersion": "v2_0",
    "image": "confluentinc/cp-flink:2.0.0-cp1",
    "jobManager": {
      "resource": {
        "cpu": 1,
        "memory": "1024m"
      }
    },
    "taskManager": {
      "resource": {
        "cpu": 2,
        "memory": "2048m"
      }
    }
  }
}
